{
  "name": "@mister-fetch/core",
  "version": "0.1.0",
  "private": true,
  "description": "Fetch runtime: anguish math, triage, worker loop, supervisor, termination validator. No UI, no provider, no external runtime deps.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts packages/fetch-core/src",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "playwright": "1.61.1"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "@types/node": "22.19.17"
  }
}
